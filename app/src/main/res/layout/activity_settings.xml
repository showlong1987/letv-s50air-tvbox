<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117"
    android:padding="50dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="[设置] 乐视TVBOX"
        android:textColor="#E50914"
        android:textSize="32sp"
        android:layout_marginBottom="40dp" />

    <!-- API URL -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="接口配置地址"
        android:textColor="#C9D1D9"
        android:textSize="20sp"
        android:layout_marginBottom="10dp" />
    <EditText
        android:id="@+id/etApiUrl"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/input_bg"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:padding="15dp"
        android:hint="请输入TVBOX接口地址"
        android:layout_marginBottom="30dp"
        android:singleLine="true" />

    <!-- Player type -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="播放器类型 (hard/soft)"
        android:textColor="#C9D1D9"
        android:textSize="20sp"
        android:layout_marginBottom="10dp" />
    <EditText
        android:id="@+id/etPlayerType"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/input_bg"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:padding="15dp"
        android:hint="hard"
        android:layout_marginBottom="30dp"
        android:singleLine="true" />

    <!-- EPG URL -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EPG节目预告地址"
        android:textColor="#C9D1D9"
        android:textSize="20sp"
        android:layout_marginBottom="10dp" />
    <EditText
        android:id="@+id/etEpgUrl"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/input_bg"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:padding="15dp"
        android:hint="https://epg.112114.xyz/"
        android:layout_marginBottom="40dp"
        android:singleLine="true" />

    <!-- Boot auto-start toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="开机自启"
            android:textColor="#C9D1D9"
            android:textSize="20sp" />

        <CheckBox
            android:id="@+id/cbBoot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:checked="true" />

    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button
            android:id="@+id/btnSave"
            android:layout_width="200dp"
            android:layout_height="65dp"
            android:text="保存"
            android:textSize="20sp"
            android:background="@drawable/btn_red"
            android:textColor="#FFFFFF"
            android:layout_marginRight="20dp" />
        <Button
            android:id="@+id/btnCancel"
            android:layout_width="200dp"
            android:layout_height="65dp"
            android:text="取消"
            android:textSize="20sp"
            android:background="@drawable/btn_dark"
            android:textColor="#C9D1D9" />
    </LinearLayout>

</LinearLayout>
